        <param key="propulsionEfficiency" value=".98"/>             <!-- Unknown -->
        <param key="recuperationEfficiency" value=".96"/>           <!-- Unknown -->
        <param key="stoppingThreshold" value="0.1"/>                <!-- Unknown -->             
        <param key="device.battery.maximumChargeRate" value="150000"/>   
<!--    <param key="device.battery.chargeLevelTable"/>                   Unknown -->  
    </vType>

