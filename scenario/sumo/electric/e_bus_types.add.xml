    <!-- Secondary Source: https://www.urban-transport-magazine.com/en/first-ebusco-2-2-for-bvg-berlin-unveiled/ -->
    <!-- This Bus Model is taken from a magazin concerning the order of 90 vehicles in 2022-->
    <vType id="Ebusco2.2electric12m"
            vClass="bus"
            guiShape="bus"
            length="12.0"
            minGap="2.50" 
            maxSpeed="29.06" 
            color="yellow" 
            accel="1.0" 
            decel="1.0" 
            sigma="0.0" 
            emissionClass="Energy/unknown" 
            mass="12850"> 
        <param key="has.battery.device" value="true"/>              <!-- Always true for electric buses -->
